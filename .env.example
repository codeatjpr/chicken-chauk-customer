# API origin without trailing slash; `/api/v1` is appended in the app.
# Example: http://localhost:5000
VITE_API_URL=

# Google Maps Platform — browser key (HTTP referrer–restricted in GCP).
# Enable: Maps JavaScript API, Places API (New), Geocoding API.
# If autocomplete returns 403 "AutocompletePlaces are blocked": in GCP → Credentials → key →
# API restrictions → ensure "Places API (New)" is allowed (or use "Don't restrict key" for local dev).
# Vite inlines this at build time — set on the server before `npm run build` in production.
# VITE_GOOGLE_MAPS_API_KEY=

# Optional: browser error reporting (leave empty to disable).
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Optional: mobile store URLs for footer / CTAs (full HTTPS URLs).
# VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=...
# VITE_APP_STORE_URL=https://apps.apple.com/app/...

# Playwright (optional override for e2e)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173
