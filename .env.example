# API origin without trailing slash; `/api/v1` is appended in the app.
# Example: http://localhost:5000
VITE_API_URL=

# Optional: browser error reporting (leave empty to disable).
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Playwright (optional override for e2e)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173
